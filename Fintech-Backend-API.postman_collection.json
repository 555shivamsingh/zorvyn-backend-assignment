            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"QA Analyst\",\n  \"email\": \"qa.analyst@example.com\",\n  \"password\": \"StrongPass123\",\n  \"role\": \"ANALYST\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
